{
  "name": "soccli",
  "version": "0.1.0",
  "description": "Terminal-first real-time protocol CLI for WebSocket, Pusher/Reverb, Socket.IO, and GraphQL subscriptions.",
  "type": "module",
  "bin": {
    "soccli": "./bin/soccli.js"
  },
  "scripts": {
    "start": "node ./bin/soccli.js",
    "check": "node --check ./bin/soccli.js",
    "lint": "node --check ./src/cli/program.js"
  },
  "engines": {
    "node": ">=18.17"
  },
  "keywords": [
    "cli",
    "websocket",
    "pusher",
    "socket.io",
    "graphql",
    "subscriptions",
    "reverb"
  ],
  "license": "MIT",
  "dependencies": {
    "commander": "^12.1.0",
    "ws": "^8.18.0"
  }
}
